# Health Tracker — Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Google Sheets
SHEET_ID=your-google-sheet-id-here
JSON_KEY_FILE=service-account-key.json

# Garmin Connect
GARMIN_EMAIL=your-email@example.com
# Garmin password is stored in system keyring, not here.
# Set it with: python -c "import keyring; keyring.set_password('garmin_connect', 'your-email@example.com', 'your-password')"

# Pushover Notifications (optional)
PUSHOVER_USER_KEY=
PUSHOVER_API_TOKEN=
